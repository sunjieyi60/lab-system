{
  "taskGroup": {
    "id": 1,
    "name": "环境监控-告警任务组",
    "cron": "0 */5 * * * ?",
    "enable": true,
    "timeRule": {
      "businessTime": ["09:00-12:00", "13:30-18:00"],
      "weekdays": [1, 2, 3, 4, 5],
      "weekParity": "ALL",
      "dateRange": ["2025-01-01", "2025-12-31"],
      "timezone": "Asia/Shanghai"
    }
  },
  "dataGroups": [
    {
      "id": 100,
      "name": "室内温度",
      "type": "TEMPERATURE",
      "fetchConfig": { "deviceId": "temp-001", "metric": "temp", "windowMinutes": 5, "agg": "AVG" },
      "agg": "AVG",
      "mockValue": 32.5
    },
    {
      "id": 101,
      "name": "室内光照",
      "type": "LIGHT",
      "fetchConfig": { "deviceId": "light-001", "metric": "lux", "windowMinutes": 5, "agg": "AVG" },
      "agg": "AVG",
      "mockValue": 120
    }
  ],
  "conditionGroup": {
    "logic": "ALL",
    "conditions": [
      { "id": 201, "expr": "#data[100] > 30", "desc": "温度 > 30℃" },
      { "id": 202, "expr": "#data[101] < 200", "desc": "光照 < 200 lux" }
    ]
  },
  "actions": [
    {
      "id": 301,
      "name": "推送短信",
      "type": "SMS",
      "payload": { "to": ["13800000000"], "template": "温度告警", "vars": { "temp": "#data[100]" } },
      "order": 1,
      "retryTimes": 1
    },
    {
      "id": 302,
      "name": "发送邮件",
      "type": "SMTP",
      "payload": { "to": ["ops@example.com"], "subject": "温度光照告警", "body": "温度与光照异常" },
      "order": 2,
      "retryTimes": 0
    }
  ],
  "alerts": {
    "channels": [
      { "id": 401, "type": "SMS", "config": { "provider": "mock", "apiKey": "demo" } },
      { "id": 402, "type": "SMTP", "config": { "host": "smtp.example.com", "from": "noreply@example.com", "to": ["ops@example.com"] } }
    ],
    "strategy": {
      "enable": true,
      "throttleMs": 600000,
      "continuousFailThreshold": 1,
      "bindChannels": [401, 402]
    }
  }
}



